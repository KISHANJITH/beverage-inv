<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Bar Inventory Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:#0c0e14; --bg2:#13161f; --bg3:#1a1e2b; --bg4:#1f2435;
  --border:rgba(255,255,255,0.07); --border2:rgba(255,255,255,0.13);
  --text:#e8eaf2; --text2:#7c849e; --text3:#464f6a;
  --accent:#4f8ef7; --accent-bg:rgba(79,142,247,0.13);
  --bar:#4f8ef7; --bar-bg:rgba(79,142,247,0.13);
  --floor:#b07cf7; --floor-bg:rgba(176,124,247,0.14);
  --green:#3ecf8e; --green-bg:rgba(62,207,142,0.13);
  --amber:#f5a623; --amber-bg:rgba(245,166,35,0.13);
  --red:#f26464; --red-bg:rgba(242,100,100,0.13);
  --radius:10px; --radius-lg:14px; --shadow:0 2px 12px rgba(0,0,0,0.4);
}
body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; }

.app-header { background:var(--bg2); border-bottom:1px solid var(--border); padding:14px 20px; position:sticky; top:0; z-index:200; display:flex; align-items:center; justify-content:space-between; gap:12px; }
.header-left h1 { font-size:16px; font-weight:600; letter-spacing:-0.3px; }
.header-left p { font-size:11px; color:var(--text2); margin-top:2px; }
.header-right { display:flex; gap:8px; align-items:center; flex-shrink:0; }

#toast { position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(80px); background:#2a3044; border:1px solid var(--border2); border-radius:var(--radius); padding:10px 20px; font-size:13px; color:var(--text); z-index:999; transition:transform 0.3s cubic-bezier(0.4,0,0.2,1); pointer-events:none; white-space:nowrap; box-shadow:var(--shadow); max-width:90vw; }
#toast.show { transform:translateX(-50%) translateY(0); }

.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.7); z-index:500; display:flex; align-items:center; justify-content:center; padding:20px; opacity:0; pointer-events:none; transition:opacity 0.2s; }
.modal-overlay.open { opacity:1; pointer-events:all; }
.modal { background:var(--bg2); border:1px solid var(--border2); border-radius:var(--radius-lg); padding:24px; max-width:380px; width:100%; box-shadow:var(--shadow); transform:scale(0.95); transition:transform 0.2s; }
.modal-overlay.open .modal { transform:scale(1); }
.modal h3 { font-size:16px; font-weight:600; margin-bottom:8px; }
.modal p { font-size:13px; color:var(--text2); margin-bottom:20px; line-height:1.5; }
.modal-btns { display:flex; gap:8px; justify-content:flex-end; }

.shop-row { display:flex; align-items:center; justify-content:space-between; padding:10px 12px; background:var(--bg3); border-radius:var(--radius); margin-bottom:6px; }
.shop-name { font-size:13px; font-weight:600; }
.shop-cat { font-size:10px; color:var(--text3); }
.shop-levels { display:flex; gap:8px; align-items:center; }
.shop-tag { font-size:10px; font-weight:600; padding:2px 7px; border-radius:12px; font-family:'DM Mono',monospace; white-space:nowrap; }
.shop-tag.bar { background:var(--bar-bg); color:var(--bar); }
.shop-tag.floor { background:var(--floor-bg); color:var(--floor); }
.shop-empty { text-align:center; padding:24px; color:var(--green); font-size:13px; }

.main { max-width:920px; margin:0 auto; padding:20px 16px 80px; }

/* SUMMARY - two location columns */
.loc-summary { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:20px; }
.loc-panel { background:var(--bg2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:14px 16px; }
.loc-panel.bar { border-top:3px solid var(--bar); }
.loc-panel.floor { border-top:3px solid var(--floor); }
.loc-title { font-size:13px; font-weight:600; margin-bottom:10px; display:flex; align-items:center; gap:7px; }
.loc-dot { width:10px; height:10px; border-radius:50%; }
.loc-dot.bar { background:var(--bar); }
.loc-dot.floor { background:var(--floor); }
.loc-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
.mini-stat { }
.mini-label { font-size:9px; color:var(--text3); text-transform:uppercase; letter-spacing:0.05em; }
.mini-val { font-size:18px; font-weight:600; font-family:'DM Mono',monospace; }

.controls { display:flex; gap:8px; margin-bottom:16px; flex-wrap:wrap; align-items:center; }
.search-wrap { flex:1; min-width:160px; position:relative; }
.search-wrap input { padding-right:32px; width:100%; }
.search-clear { position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text3); cursor:pointer; font-size:14px; display:none; line-height:1; padding:2px; }
.search-clear.visible { display:block; }
.search-clear:hover { color:var(--text); }
input, select { background:var(--bg2); border:1px solid var(--border); border-radius:var(--radius); color:var(--text); font-family:'DM Sans',sans-serif; font-size:13px; padding:8px 12px; height:38px; width:100%; outline:none; transition:border-color 0.15s; }
input:focus, select:focus { border-color:var(--accent); }
input::placeholder { color:var(--text3); }
select option { background:#1a1e2b; }
label { font-size:11px; color:var(--text2); display:block; margin-bottom:4px; }
.btn { background:var(--bg2); border:1px solid var(--border2); border-radius:var(--radius); color:var(--text); font-family:'DM Sans',sans-serif; font-size:13px; font-weight:500; padding:0 14px; height:38px; cursor:pointer; white-space:nowrap; transition:all 0.15s; display:inline-flex; align-items:center; gap:6px; }
.btn:hover { background:var(--bg3); border-color:var(--border2); }
.btn-primary { background:var(--accent); border-color:var(--accent); color:#fff; }
.btn-primary:hover { background:#3a7de8; }
.btn-amber { background:var(--amber-bg); border-color:var(--amber); color:var(--amber); }
.btn-amber:hover { background:var(--amber); color:#fff; }
.btn-danger { background:var(--red-bg); border-color:var(--red); color:var(--red); }
.btn-danger:hover { background:var(--red); color:#fff; }
.btn-sm { height:32px; font-size:12px; padding:0 10px; }

.add-panel { background:var(--bg2); border:1px solid var(--accent); border-radius:var(--radius-lg); padding:16px; margin-bottom:16px; display:none; }
.add-panel.open { display:block; }
.add-grid { display:grid; grid-template-columns:2fr 1fr 1fr; gap:10px; margin-bottom:10px; }
.add-footer { display:flex; gap:8px; align-items:flex-end; }
.add-footer .cat-wrap { flex:1; }

.cat-controls { display:flex; gap:8px; margin-bottom:4px; }
.text-btn { background:none; border:none; color:var(--text2); cursor:pointer; font-size:11px; font-family:'DM Sans',sans-serif; padding:4px 8px; border-radius:6px; transition:all 0.15s; }
.text-btn:hover { background:var(--bg3); color:var(--text); }

.section-divider { font-size:10px; font-weight:600; color:var(--text3); text-transform:uppercase; letter-spacing:0.1em; margin:20px 0 8px; padding-bottom:6px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; cursor:pointer; user-select:none; }
.section-divider:hover { color:var(--text2); }
.section-divider .right { display:flex; align-items:center; gap:10px; }
.section-divider .count { font-weight:400; }
.section-divider .chevron { font-size:12px; transition:transform 0.2s; }
.section-divider.collapsed .chevron { transform:rotate(-90deg); }

.bottles-grid { display:flex; flex-direction:column; gap:8px; }
.bottles-grid.collapsed { display:none; }
.bottle-card { background:var(--bg2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:12px 14px; transition:border-color 0.2s; }
.bottle-card:hover { border-color:var(--border2); }

.card-head { display:flex; align-items:center; justify-content:space-between; gap:8px; }
.bottle-name { font-size:13px; font-weight:600; color:var(--text); }
.bottle-meta { font-size:11px; color:var(--text3); margin-top:1px; }

.loc-row { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:10px; }
.loc-cell { background:var(--bg3); border-radius:var(--radius); padding:10px; border:1px solid transparent; }
.loc-cell.bar { border-left:3px solid var(--bar); }
.loc-cell.floor { border-left:3px solid var(--floor); }
.loc-cell-head { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; gap:6px; }
.loc-cell-name { font-size:11px; font-weight:600; color:var(--text2); display:flex; align-items:center; gap:5px; flex-shrink:0; }
.loc-total-badge { font-size:11px; font-weight:600; font-family:'DM Mono',monospace; padding:3px 9px; border-radius:20px; white-space:nowrap; flex-shrink:0; }
.loc-total-badge.bar { background:var(--bar-bg); color:var(--bar); }
.loc-total-badge.floor { background:var(--floor-bg); color:var(--floor); }
.loc-total-badge.hide { display:none; }

.cell-inputs { display:flex; align-items:flex-end; gap:8px; }
.cell-inputs .input-group { display:flex; flex-direction:column; gap:3px; }
.cell-inputs input.weight { width:88px; height:44px; font-size:15px; }
.cell-inputs label { font-size:10px; }
.fill-readout { display:flex; flex-direction:column; align-items:center; gap:2px; min-width:42px; }
.fill-num { font-size:14px; font-weight:600; font-family:'DM Mono',monospace; }
.fill-word { font-size:9px; color:var(--text3); }
.full-counter { display:flex; align-items:center; gap:6px; }
.qty-btn { width:34px; height:34px; border-radius:50%; border:1px solid var(--border2); background:var(--bg2); color:var(--text); cursor:pointer; font-size:18px; display:flex; align-items:center; justify-content:center; transition:all 0.15s; line-height:1; flex-shrink:0; -webkit-tap-highlight-color:transparent; }
.qty-btn:hover { background:var(--accent-bg); border-color:var(--accent); color:var(--accent); }
.qty-btn:active { transform:scale(0.9); }
.qty-num { font-size:14px; font-weight:600; min-width:20px; text-align:center; font-family:'DM Mono',monospace; }

.del-btn { background:none; border:none; cursor:pointer; color:var(--text3); font-size:15px; padding:6px; border-radius:8px; transition:all 0.15s; }
.del-btn:hover { background:var(--red-bg); color:var(--red); }

.empty { text-align:center; padding:48px 20px; color:var(--text3); font-size:14px; border:1px dashed var(--border); border-radius:var(--radius-lg); }
.empty-icon { font-size:32px; margin-bottom:8px; }

#scroll-top { position:fixed; bottom:24px; right:24px; width:44px; height:44px; border-radius:50%; background:var(--accent); border:none; color:#fff; font-size:20px; cursor:pointer; z-index:300; box-shadow:var(--shadow); opacity:0; pointer-events:none; transition:all 0.25s; transform:translateY(10px); display:flex; align-items:center; justify-content:center; }
#scroll-top.show { opacity:1; pointer-events:all; transform:translateY(0); }
#scroll-top:hover { background:#3a7de8; }

@media print {
  .app-header .header-right, .controls, .add-panel, .del-btn, .qty-btn, .cat-controls, #scroll-top { display:none !important; }
  .bottle-card { break-inside:avoid; border:1px solid #ccc !important; }
  body { background:#fff; color:#000; }
}
@media(max-width:640px){
  .loc-summary { grid-template-columns:1fr; }
  .add-grid { grid-template-columns:1fr 1fr; }
  .loc-row { grid-template-columns:1fr; }
  .cell-inputs input.weight { width:80px; height:44px; }
  .app-header { flex-wrap:wrap; }
  .header-right { width:100%; justify-content:flex-end; }
}
</style>
</head>
<body>

<div id="toast"></div>

<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <h3 id="modal-title">Are you sure?</h3>
    <p id="modal-body">This action cannot be undone.</p>
    <div class="modal-btns">
      <button class="btn" onclick="closeModal()">Cancel</button>
      <button class="btn btn-danger" id="modal-confirm">Confirm</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="shop-overlay">
  <div class="modal" style="max-width:440px;">
    <h3>🛒 Reorder List</h3>
    <p style="margin-bottom:14px;">Bottles below 25% in either location.</p>
    <div id="shop-list" style="max-height:50vh;overflow-y:auto;margin-bottom:18px;"></div>
    <div class="modal-btns">
      <button class="btn" onclick="copyShoppingList()">📋 Copy</button>
      <button class="btn btn-primary" onclick="closeShopModal()">Done</button>
    </div>
  </div>
</div>


<div class="app-header">
  <div class="header-left">
    <h1>🍾 Bar Inventory Tracker</h1>
    <p id="last-saved-label">No data saved yet</p>
  </div>
  <div class="header-right">
    <button class="btn btn-sm" onclick="showShoppingList()" title="Low stock shopping list">🛒 Reorder</button>
    <button class="btn btn-sm" onclick="exportCSV()" title="Export to CSV">📊 Export</button>
    <button class="btn btn-sm" onclick="window.print()" title="Print">🖨 Print</button>
    <button class="btn btn-sm btn-amber" onclick="confirmReset()" title="Clear all counts">🔄 New Count</button>
  </div>
</div>

<div class="main">

  <!-- TWO LOCATION SUMMARY -->
  <div class="loc-summary">
    <div class="loc-panel bar">
      <div class="loc-title"><span class="loc-dot bar"></span> Bar</div>
      <div class="loc-stats">
        <div class="mini-stat"><div class="mini-label">Weighed</div><div class="mini-val" id="bar-weighed">0</div></div>
        <div class="mini-stat"><div class="mini-label">Low / Empty</div><div class="mini-val" id="bar-low" style="color:var(--amber)">0</div></div>
        <div class="mini-stat"><div class="mini-label">Full stored</div><div class="mini-val" id="bar-full" style="color:var(--green)">0</div></div>
      </div>
    </div>
    <div class="loc-panel floor">
      <div class="loc-title"><span class="loc-dot floor"></span> 3rd Floor</div>
      <div class="loc-stats">
        <div class="mini-stat"><div class="mini-label">Weighed</div><div class="mini-val" id="floor-weighed">0</div></div>
        <div class="mini-stat"><div class="mini-label">Low / Empty</div><div class="mini-val" id="floor-low" style="color:var(--amber)">0</div></div>
        <div class="mini-stat"><div class="mini-label">Full stored</div><div class="mini-val" id="floor-full" style="color:var(--green)">0</div></div>
      </div>
    </div>
  </div>

  <div class="controls">
    <div class="search-wrap">
      <input type="text" id="search" placeholder="🔍  Search bottles..." oninput="onSearch()" />
      <button class="search-clear" id="search-clear" onclick="clearSearch()">✕</button>
    </div>
    <select id="filter-cat" onchange="render()" style="width:auto;min-width:145px;">
      <option value="">All categories</option>
      <option>40 oz Bottles</option><option>Rum</option><option>Gin</option><option>Irish Whiskey</option>
      <option>Liqueur</option><option>Rye Whiskey</option><option>Scotch</option>
      <option>Sherry &amp; Port</option><option>Tequila</option><option>Vermouth</option><option>Vodka</option>
    </select>
    <button class="btn btn-primary" onclick="toggleAdd()">+ Add bottle</button>
  </div>

  <div class="add-panel" id="add-panel">
    <div style="font-size:13px;font-weight:600;margin-bottom:12px;color:var(--accent);">➕ Add new bottle (appears in both locations)</div>
    <div class="add-grid">
      <div><label>Bottle name</label><input type="text" id="inp-name" placeholder="e.g. Hendricks" /></div>
      <div><label>Size (oz)</label><input type="number" id="inp-size" placeholder="26" min="1" step="0.1" /></div>
      <div><label>Empty weight (oz)</label><input type="number" id="inp-tare" placeholder="0.0" min="0" step="0.1" /></div>
    </div>
    <div class="add-footer">
      <div class="cat-wrap"><label>Category</label>
        <select id="inp-cat">
          <option>40 oz Bottles</option><option>Rum</option><option>Gin</option><option>Irish Whiskey</option>
          <option>Liqueur</option><option>Rye Whiskey</option><option>Scotch</option>
          <option>Sherry &amp; Port</option><option>Tequila</option><option>Vermouth</option><option>Vodka</option><option>Other</option>
        </select>
      </div>
      <button class="btn btn-primary" onclick="addBottle()">Add</button>
      <button class="btn" onclick="toggleAdd()">Cancel</button>
    </div>
  </div>

  <div class="cat-controls">
    <button class="text-btn" onclick="setAllCollapsed(false)">⊕ Expand all</button>
    <button class="text-btn" onclick="setAllCollapsed(true)">⊖ Collapse all</button>
  </div>

  <div id="bottles-container"></div>
</div>

<button id="scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" title="Back to top">↑</button>

