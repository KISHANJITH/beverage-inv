  {cat:"Vodka",size:26,name:"Smirnoff Apple",tare:16.8},
  {cat:"Vodka",size:26,name:"Tito's",tare:13.1},
  {cat:"Vodka",size:26,name:"Stolichnaya",tare:16},
  {cat:"Vodka",size:26,name:"Absolut",tare:17.7},
  {cat:"Vodka",size:26,name:"Ketel One",tare:22.3},
  {cat:"Vodka",size:40,name:"Stolichnaya",tare:24.5},
  {cat:"Vodka",size:40,name:"Absolut",tare:24.8},
  {cat:"Vodka",size:40,name:"Smirnoff",tare:21.5},
];

let bottles=[];
let nextId=1;
let collapsedCats={};
let modalCallback=null;
const STORAGE_KEY='bar_inventory_v3';

function saveToStorage(){
  const data={ bottles, nextId, collapsedCats, savedAt:new Date().toISOString() };
  try{ localStorage.setItem(STORAGE_KEY,JSON.stringify(data)); updateLastSaved(data.savedAt); }
  catch(e){ showToast('⚠️ Could not save — storage may be full or blocked.',4000); }
}
function loadFromStorage(){
  try{
    const raw=localStorage.getItem(STORAGE_KEY);
    if(!raw) return false;
    const data=JSON.parse(raw);
    bottles=data.bottles||[];
    nextId=data.nextId||bottles.length+1;
    collapsedCats=data.collapsedCats||{};
    updateLastSaved(data.savedAt);
    return true;
  }catch(e){ return false; }
}
function updateLastSaved(iso){
  const el=document.getElementById('last-saved-label');
  if(!iso){el.textContent='No data saved yet';return;}
  const d=new Date(iso);
  el.textContent='Last saved: '+d.toLocaleDateString()+' at '+d.toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
}

let toastTimer=null;
function showToast(msg,duration=2500){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>t.classList.remove('show'),duration);
}
function hideToast(){
  const t=document.getElementById('toast');
  t.classList.remove('show');
  clearTimeout(toastTimer);
}

function openModal(title,body,confirmLabel,cb,danger=true){
  document.getElementById('modal-title').textContent=title;
  document.getElementById('modal-body').textContent=body;
  const btn=document.getElementById('modal-confirm');
  btn.textContent=confirmLabel;
  btn.className='btn '+(danger?'btn-danger':'btn-amber');
  modalCallback=cb;
  document.getElementById('modal-overlay').classList.add('open');
}
function closeModal(){ document.getElementById('modal-overlay').classList.remove('open'); modalCallback=null; }
document.getElementById('modal-confirm').addEventListener('click',()=>{ if(modalCallback) modalCallback(); closeModal(); });
document.getElementById('modal-overlay').addEventListener('click',function(e){ if(e.target===this) closeModal(); });

function onSearch(){
  const val=document.getElementById('search').value;
  document.getElementById('search-clear').classList.toggle('visible',val.length>0);
  render();
}
function clearSearch(){ document.getElementById('search').value=''; document.getElementById('search-clear').classList.remove('visible'); render(); }

function toggleAdd(){
  const p=document.getElementById('add-panel');
  const isOpen=p.classList.contains('open');
  p.classList.toggle('open');
  if(!isOpen) document.getElementById('inp-name').focus();
}
function addBottle(){
  const name=document.getElementById('inp-name').value.trim();
  const size=parseFloat(document.getElementById('inp-size').value);
  const tare=parseFloat(document.getElementById('inp-tare').value);
  const cat=document.getElementById('inp-cat').value;
  if(!name||!size||isNaN(tare)){showToast('⚠️ Please fill in all fields.');return;}
  bottles.push({id:nextId++,name,size,tare,cat,
    w_bar:null, w_floor:null, f_bar:0, f_floor:0});
  document.getElementById('inp-name').value='';
  document.getElementById('inp-size').value='';
  document.getElementById('inp-tare').value='';
  document.getElementById('add-panel').classList.remove('open');
  saveToStorage(); render(); showToast('✅ '+name+' added to both locations!');
}
function removeBottle(id){
  const b=bottles.find(b=>b.id===id);
  openModal('Remove bottle?','Remove "'+b.name+'" from both locations? This cannot be undone.','Remove',()=>{
    bottles=bottles.filter(b=>b.id!==id); saveToStorage(); render(); showToast('🗑 Removed.');
  });
}
function confirmReset(){
  openModal('Start new count?','This clears all weights and full counts for BOTH locations, keeping your bottle list. Use at the start of each inventory count.','Clear & start fresh',()=>{
    bottles.forEach(b=>{ b.w_bar=null; b.w_floor=null; b.f_bar=0; b.f_floor=0; });
    saveToStorage(); render(); showToast('🔄 All counts cleared for both locations!');
  },false);
}

let warnTimer=null;
function updateWeight(id,loc,val){
  const b=bottles.find(b=>b.id===id);
  if(b){
    const parsed=val===''?null:parseFloat(val);
    b['w_'+loc]=parsed;

    // Decide if the current value is out of range
    let warning=null;
    if(parsed!==null&&!isNaN(parsed)){
      if(parsed>0&&parsed<b.tare) warning='⚠️ '+parsed+' oz is below empty weight ('+b.tare+' oz). Check reading.';
      else if(parsed>b.tare+b.size+1) warning='⚠️ '+parsed+' oz is above full ('+(b.tare+b.size).toFixed(1)+' oz). Check reading.';
    }

    clearTimeout(warnTimer);
    if(warning){
      // Wait until typing pauses (700ms) before warning, so mid-typing digits don't trigger it
      warnTimer=setTimeout(()=>showToast(warning,2500),700);
    } else {
      // Value is now valid (or cleared) — dismiss any warning immediately
      hideToast();
    }
  }
  updateCardVisual(id); updateSummary(); saveToStorage();
}
function changeFullQty(id,loc,delta){
  const b=bottles.find(b=>b.id===id);
  if(!b) return;
  b['f_'+loc]=Math.max(0,(b['f_'+loc]||0)+delta);
  updateCardVisual(id); updateSummary(); saveToStorage();
}

function calcRatio(b,loc){
  const w=b['w_'+loc];
  if(w===null||isNaN(w)) return null;
  return Math.min(1,Math.max(0,(w-b.tare)/b.size));
}
function calcTotal(b,loc){
  const r=calcRatio(b,loc);
  return (b['f_'+loc]||0)+(r!==null?r:0);
}
function getLevelColor(r){ if(r>0.6) return '#3ecf8e'; if(r>0.35) return '#f5a623'; return '#f26464'; }
function getLevelText(r){
  if(r===null) return{num:'—',word:''};
  if(r>=0.98) return{num:'1.00',word:'Full'};
  if(r>=0.73) return{num:r.toFixed(2),word:'¾'};
  if(r>=0.48) return{num:r.toFixed(2),word:'Half'};
  if(r>=0.23) return{num:r.toFixed(2),word:'¼'};
  if(r>0.01) return{num:r.toFixed(2),word:'Low'};
  return{num:'0.00',word:'Empty'};
}

function updateCardVisual(id){
  const b=bottles.find(b=>b.id===id);
  if(!b) return;
  LOCS.forEach(L=>{
    const loc=L.key;
    const r=calcRatio(b,loc);
    const t=getLevelText(r);
    const fnum=document.getElementById(loc+'-fnum-'+id);
    const num=document.getElementById(loc+'-fnumr-'+id);
    const word=document.getElementById(loc+'-fword-'+id);
    const badge=document.getElementById(loc+'-total-'+id);
    const inp=document.getElementById(loc+'-winp-'+id);
    if(fnum) fnum.textContent=b['f_'+loc]||0;
    if(num) num.textContent=t.num;
    if(num) num.style.color=(r!==null?getLevelColor(r):'var(--text3)');
    if(word) word.textContent=t.word;
    if(inp) inp.style.borderColor=(b['w_'+loc]!==null?'rgba(79,142,247,0.4)':'');
    if(badge){
      const total=calcTotal(b,loc);
      const hasData=(b['w_'+loc]!==null)||(b['f_'+loc]>0);
      if(hasData&&total>0){ badge.classList.remove('hide'); badge.textContent=total.toFixed(2)+' btl'; }
      else badge.classList.add('hide');
    }
  });
}

function updateSummary(){
  LOCS.forEach(L=>{
    const loc=L.key;
    const withW=bottles.filter(b=>b['w_'+loc]!==null);
    const ratios=withW.map(b=>calcRatio(b,loc)).filter(r=>r!==null);
    const lowEmpty=ratios.filter(r=>r<0.25).length;
    document.getElementById(loc+'-weighed').textContent=withW.length;
    document.getElementById(loc+'-low').textContent=lowEmpty;
    document.getElementById(loc+'-full').textContent=bottles.reduce((a,b)=>a+(b['f_'+loc]||0),0);
  });
}

// ── SHOPPING / REORDER LIST ──
function getLowBottles(){
  // A bottle qualifies if EITHER location is weighed and at/below 25%
  return bottles.map(b=>{
    const rb=calcRatio(b,'bar');
    const rf=calcRatio(b,'floor');
    const barLow=(rb!==null&&rb<0.25);
    const floorLow=(rf!==null&&rf<0.25);
    return {b,rb,rf,barLow,floorLow,low:(barLow||floorLow)};
  }).filter(x=>x.low);
}

function showShoppingList(){
  const low=getLowBottles();
  const list=document.getElementById('shop-list');
  if(low.length===0){
    list.innerHTML='<div class="shop-empty">✅ Nothing low — all stocked up!</div>';
  } else {
    // Order by lowest combined ratio first
    low.sort((a,b)=>{
      const am=Math.min(a.rb===null?9:a.rb, a.rf===null?9:a.rf);
      const bm=Math.min(b.rb===null?9:b.rb, b.rf===null?9:b.rf);
      return am-bm;
    });
    list.innerHTML=low.map(x=>{
      const tags=[];
      if(x.barLow) tags.push('<span class="shop-tag bar">Bar '+x.rb.toFixed(2)+'</span>');
      if(x.floorLow) tags.push('<span class="shop-tag floor">3F '+x.rf.toFixed(2)+'</span>');
      return '<div class="shop-row"><div><div class="shop-name">'+x.b.name+'</div><div class="shop-cat">'+x.b.cat+' · '+x.b.size+' oz</div></div><div class="shop-levels">'+tags.join('')+'</div></div>';
    }).join('');
  }
  document.getElementById('shop-overlay').classList.add('open');
}
function closeShopModal(){ document.getElementById('shop-overlay').classList.remove('open'); }
function copyShoppingList(){
  const low=getLowBottles();
  if(low.length===0){ showToast('Nothing low to copy.'); return; }
  const lines=['REORDER LIST — '+new Date().toLocaleDateString()];
  low.forEach(x=>{
    const where=[];
    if(x.barLow) where.push('Bar '+x.rb.toFixed(2));
    if(x.floorLow) where.push('3rd Floor '+x.rf.toFixed(2));
    lines.push('• '+x.b.name+' ('+x.b.size+'oz) — '+where.join(', '));
  });
  const text=lines.join('\n');
  if(navigator.clipboard&&navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(()=>showToast('📋 Copied reorder list!'),()=>showToast('Could not copy.'));
  } else {
    // Fallback
    const ta=document.createElement('textarea');
    ta.value=text; document.body.appendChild(ta); ta.select();
    try{ document.execCommand('copy'); showToast('📋 Copied reorder list!'); }
    catch(e){ showToast('Could not copy.'); }
    document.body.removeChild(ta);
  }
}
document.getElementById('shop-overlay').addEventListener('click',function(e){ if(e.target===this) closeShopModal(); });

function exportCSV(){
  const rows=[['Category','Name','Size (oz)','Empty (oz)',
    'Bar Weight','Bar Fill','Bar Full','Bar Total',
    '3rd Floor Weight','3rd Floor Fill','3rd Floor Full','3rd Floor Total']];
  bottles.forEach(b=>{
    const rb=calcRatio(b,'bar'), rf=calcRatio(b,'floor');
    rows.push([b.cat,b.name,b.size,b.tare,
      b.w_bar??'', rb!==null?rb.toFixed(2):'', b.f_bar||0, (b.w_bar!==null||b.f_bar>0)?calcTotal(b,'bar').toFixed(2):'',
      b.w_floor??'', rf!==null?rf.toFixed(2):'', b.f_floor||0, (b.w_floor!==null||b.f_floor>0)?calcTotal(b,'floor').toFixed(2):''
    ]);
  });
  const csv=rows.map(r=>r.map(v=>'"'+String(v).replace(/"/g,'""')+'"').join(',')).join('\n');
  const blob=new Blob([csv],{type:'text/csv'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');
  a.href=url; a.download='bar-inventory-'+new Date().toISOString().slice(0,10)+'.csv';
  a.click(); URL.revokeObjectURL(url);
  showToast('📊 CSV exported (both locations)!');
}

function toggleCat(cat){
  collapsedCats[cat]=!collapsedCats[cat];
  const s=cat.replace(/\s+/g,'_');
  document.getElementById('div-'+s)?.classList.toggle('collapsed',!!collapsedCats[cat]);
  document.getElementById('grid-'+s)?.classList.toggle('collapsed',!!collapsedCats[cat]);
  saveToStorage();
}
function setAllCollapsed(c){ CAT_ORDER.forEach(cat=>{collapsedCats[cat]=c;}); saveToStorage(); render(); }

function locCell(b,L){
  const loc=L.key;
  const r=calcRatio(b,loc);
  const t=getLevelText(r);
  const fq=b['f_'+loc]||0;
  const total=calcTotal(b,loc);
  const hasData=(b['w_'+loc]!==null)||(fq>0);
  const col=r!==null?getLevelColor(r):'var(--text3)';
  return `
    <div class="loc-cell ${loc}">
      <div class="loc-cell-head">
        <div class="loc-cell-name"><span class="loc-dot ${loc}"></span>${L.label}</div>
        <span id="${loc}-total-${b.id}" class="loc-total-badge ${loc} ${hasData&&total>0?'':'hide'}">${total.toFixed(2)} btl</span>
      </div>
      <div class="cell-inputs">
        <div class="input-group">
          <label>Weight (oz)</label>
          <input class="weight" type="number" min="0" step="0.1" id="${loc}-winp-${b.id}"
            placeholder="${b.tare}–${(b.tare+b.size).toFixed(1)}"
            value="${b['w_'+loc]!==null?b['w_'+loc]:''}"
            style="${b['w_'+loc]!==null?'border-color:rgba(79,142,247,0.4)':''}"
            oninput="updateWeight(${b.id},'${loc}',this.value)" />
        </div>
        <div class="fill-readout">
          <span class="fill-num" id="${loc}-fnumr-${b.id}" style="color:${col}">${t.num}</span>
          <span class="fill-word" id="${loc}-fword-${b.id}">${t.word}</span>
        </div>
        <div class="input-group">
          <label>Full</label>
          <div class="full-counter">
            <button class="qty-btn" onclick="changeFullQty(${b.id},'${loc}',-1)">−</button>
            <span class="qty-num" id="${loc}-fnum-${b.id}">${fq}</span>
            <button class="qty-btn" onclick="changeFullQty(${b.id},'${loc}',1)">+</button>
          </div>
        </div>
      </div>
    </div>`;
}

function render(){
  const search=document.getElementById('search').value.toLowerCase();
  const catF=document.getElementById('filter-cat').value;
  const filtered=bottles.filter(b=>{
    if(search&&!b.name.toLowerCase().includes(search)&&!b.cat.toLowerCase().includes(search)) return false;
    if(catF&&b.cat!==catF) return false;
    return true;
  });
  const usedCats=CAT_ORDER.filter(c=>filtered.some(b=>b.cat===c));
  const container=document.getElementById('bottles-container');
  container.innerHTML='';
  if(filtered.length===0){
    container.innerHTML='<div class="empty"><div class="empty-icon">🔍</div>No bottles match your filters.</div>';
    updateSummary();return;
  }
  usedCats.forEach(cat=>{
    const catBottles=filtered.filter(b=>b.cat===cat);
    const s=cat.replace(/\s+/g,'_');
    const isCol=!!collapsedCats[cat];
    const divider=document.createElement('div');
    divider.className='section-divider'+(isCol?' collapsed':'');
    divider.id='div-'+s;
    divider.onclick=()=>toggleCat(cat);
    divider.innerHTML=`<span>Liquor – ${cat}</span><span class="right"><span class="count">(${catBottles.length})</span><span class="chevron">▾</span></span>`;
    container.appendChild(divider);
    const grid=document.createElement('div');
    grid.className='bottles-grid'+(isCol?' collapsed':'');
    grid.id='grid-'+s;
    catBottles.forEach(b=>{
      const card=document.createElement('div');
      card.className='bottle-card';
      card.id='card-'+b.id;
      card.innerHTML=`
        <div class="card-head">
          <div>
            <div class="bottle-name">${b.name}</div>
            <div class="bottle-meta">${b.size} oz · Empty: ${b.tare} oz · Full = ${(b.size+b.tare).toFixed(1)} oz</div>
          </div>
          <button class="del-btn" onclick="removeBottle(${b.id})" title="Remove">✕</button>
        </div>
        <div class="loc-row">
          ${locCell(b,LOCS[0])}
          ${locCell(b,LOCS[1])}
        </div>`;
      grid.appendChild(card);
    });
    container.appendChild(grid);
  });
  updateSummary();
}

function init(){
  const loaded=loadFromStorage();
  if(!loaded){
    bottles=PRELOADED.map((b,i)=>({...b,id:i+1,w_bar:null,w_floor:null,f_bar:0,f_floor:0}));
    nextId=bottles.length+1;
  }
  render();
  window.addEventListener('scroll',()=>{ document.getElementById('scroll-top').classList.toggle('show',window.scrollY>400); });
  ['inp-name','inp-size','inp-tare'].forEach(idn=>{
    document.getElementById(idn).addEventListener('keydown',e=>{ if(e.key==='Enter') addBottle(); });
  });
}
init();
</script>
